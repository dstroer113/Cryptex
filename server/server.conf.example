# ============================================
# Cryptex Server Configuration (v2.0 beta)
# ============================================
# Скопируйте этот файл в server.conf рядом с бинарником
# или укажите путь через --config /path/to/server.conf
#
# Приоритет параметров:
#   1. Аргументы командной строки (--db-host, --port...)
#   2. Переменные окружения (CRYPTEX_DB_HOST...)
#   3. Этот конфиг-файл
#   4. Значения по умолчанию (ниже)

# ── База данных ───────────────────────────
[Database]
host=localhost
port=5432
name=cryptex
user=postgres
# password=your_password_here

# ── Сервер ─────────────────────────────────
[Server]
# На каком IP слушать (0.0.0.0 = все интерфейсы)
listen_ip=0.0.0.0
# Порт (должен совпадать с клиентом)
listen_port=8443
# SSL сертификат и ключ (самоподписанные или Let's Encrypt)
ssl_cert=certs/ca.crt
ssl_key=certs/ca.key

# ── Логирование ────────────────────────────
[Logging]
# Путь к лог-файлу (относительно бинарника или абсолютный)
file=cryptex_server.log
# Максимальный размер одного файла (МБ)
max_size_mb=10
# Количество файлов при ротации (cryptex_server.log, .1, .2, .3, .4)
max_files=5